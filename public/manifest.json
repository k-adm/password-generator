{
  "manifest_version": 3,
  "name": "Password Generator",
  "version": "1.1.1",
  "description": "Local, offline generator for strong random passwords and memorable passphrases. Adjustable length, character sets, and separators; nothing leaves your browser.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Password Generator",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
