{
  "name": "password-generator",
  "private": true,
  "version": "1.1.1",
  "description": "Local, offline Chrome (MV3) generator for strong random passwords and memorable diceware passphrases. Nothing leaves your browser.",
  "author": "k-adm",
  "license": "MIT",
  "homepage": "https://github.com/k-adm/password-generator#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/k-adm/password-generator.git"
  },
  "bugs": {
    "url": "https://github.com/k-adm/password-generator/issues"
  },
  "keywords": [
    "chrome-extension",
    "manifest-v3",
    "password-generator",
    "passphrase",
    "diceware",
    "eff-wordlist",
    "offline",
    "security"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run check && npm run format && vite build",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "check": "tsc -b && npm run lint",
    "preview": "vite preview",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.17",
    "@tailwindcss/postcss": "^4.1.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/chrome": "^0.2.2",
    "@types/node": "^25.2.2",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.2.4"
  }
}
